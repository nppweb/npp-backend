NODE_ENV=development
PORT=3000
GRAPHQL_PATH=/graphql

DATABASE_URL=postgresql://app:app@localhost:5432/procurement
JWT_ACCESS_SECRET=local-dev-jwt-secret-12345
JWT_ACCESS_TTL=15m
REFRESH_TOKEN_TTL_DAYS=30
INGEST_API_TOKEN=local-dev-ingest-token-12345
LOG_LEVEL=info
THROTTLE_TTL_MS=60000
THROTTLE_LIMIT=120

# Optional extra admin account for local testing.
# Seed always creates admin@admin.ru / admin.
ADMIN_EMAIL=
ADMIN_PASSWORD=
ADMIN_FULL_NAME=AIMSORA Administrator
