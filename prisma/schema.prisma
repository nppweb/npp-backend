generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  USER
  ANALYST
  ADMIN
}

enum SourceKind {
  DEMO
  FIND_TENDER
}

enum SourceRunStatus {
  PENDING
  RUNNING
  SUCCESS
  PARTIAL
  FAILED
}

enum RawEventStatus {
  RECEIVED
  NORMALIZED
  QUARANTINED
  FAILED
}

enum ProcurementStatus {
  DRAFT
  ACTIVE
  CLOSED
  ARCHIVED
}

enum ArtifactKind {
  RAW_JSON
  RAW_HTML
  REPORT_FILE
  OTHER
}

enum ReportStatus {
  PENDING
  READY
  FAILED
}

enum AuditAction {
  USER_LOGIN
  USER_LOGOUT
  USER_CREATED
  USER_ROLE_UPDATED
  USER_PASSWORD_CHANGED
  PROCUREMENT_INGESTED
}

model User {
  id           String        @id @default(uuid())
  email        String        @unique
  passwordHash String
  fullName     String
  role         UserRole      @default(USER)
  isActive     Boolean       @default(true)
  lastLoginAt  DateTime?
  deletedAt    DateTime?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  sessions     UserSession[]
  auditLogs    AuditLog[]
  reports      Report[]
  sourceRuns   SourceRun[]

  @@index([role, isActive])
}

model UserSession {
  id               String   @id @default(uuid())
  userId           String
  refreshTokenHash String   @unique
  expiresAt        DateTime
  revokedAt        DateTime?
  userAgent        String?
  ipAddress        String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt, revokedAt])
}

model Source {
  id              String           @id @default(uuid())
  code            String           @unique
  name            String
  description     String?
  kind            SourceKind
  baseUrl         String?
  isActive        Boolean          @default(true)
  config          Json?
  deletedAt       DateTime?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  runs            SourceRun[]
  rawEvents       RawEvent[]
  normalizedItems NormalizedItem[]
  procurements    Procurement[]

  @@index([kind, isActive])
}

model SourceRun {
  id              String          @id @default(uuid())
  sourceId        String
  runKey          String          @unique
  status          SourceRunStatus @default(PENDING)
  startedAt       DateTime        @default(now())
  finishedAt      DateTime?
  triggeredById   String?
  itemsDiscovered Int             @default(0)
  itemsPublished  Int             @default(0)
  itemsFailed     Int             @default(0)
  errorMessage    String?
  metadata        Json?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  source          Source          @relation(fields: [sourceId], references: [id], onDelete: Cascade)
  triggeredBy     User?           @relation(fields: [triggeredById], references: [id], onDelete: SetNull)
  rawEvents       RawEvent[]
  artifacts       Artifact[]

  @@index([sourceId, startedAt(sort: Desc)])
  @@index([status])
}

model RawEvent {
  id               String         @id @default(uuid())
  sourceId         String
  sourceRunId      String?
  eventId          String         @unique
  externalId       String?
  payloadVersion   String
  collectedAt      DateTime
  sourceUrl        String
  rawPayload       Json
  status           RawEventStatus @default(RECEIVED)
  checksum         String
  quarantineReason String?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  source           Source         @relation(fields: [sourceId], references: [id], onDelete: Cascade)
  sourceRun        SourceRun?     @relation(fields: [sourceRunId], references: [id], onDelete: SetNull)
  artifacts        Artifact[]
  normalizedItems  NormalizedItem[]

  @@index([sourceId, collectedAt(sort: Desc)])
  @@index([sourceRunId])
  @@index([status])
}

model Supplier {
  id             String        @id @default(uuid())
  name           String
  normalizedName String        @unique
  taxId          String?       @unique
  metadata       Json?
  deletedAt      DateTime?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  procurements   Procurement[]

  @@index([name])
}

model Procurement {
  id              String             @id @default(uuid())
  sourceId        String
  supplierId      String?
  externalId      String
  title           String
  description     String?
  customerName    String?
  amount          Float?
  currency        String?
  publishedAt     DateTime?
  deadlineAt      DateTime?
  status          ProcurementStatus  @default(ACTIVE)
  sourceUrl       String?
  rawPayload      Json?
  deletedAt       DateTime?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  source          Source             @relation(fields: [sourceId], references: [id], onDelete: Cascade)
  supplier        Supplier?          @relation(fields: [supplierId], references: [id], onDelete: SetNull)
  normalizedItems NormalizedItem[]

  @@unique([sourceId, externalId])
  @@index([sourceId, status])
  @@index([publishedAt(sort: Desc)])
}

model NormalizedItem {
  id              String      @id @default(uuid())
  sourceId        String
  rawEventId      String?
  procurementId   String?
  externalId      String
  payloadVersion  String
  idempotencyKey  String      @unique
  contentHash     String
  normalizedPayload Json
  normalizedAt    DateTime
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  source          Source      @relation(fields: [sourceId], references: [id], onDelete: Cascade)
  rawEvent        RawEvent?   @relation(fields: [rawEventId], references: [id], onDelete: SetNull)
  procurement     Procurement? @relation(fields: [procurementId], references: [id], onDelete: SetNull)

  @@unique([sourceId, externalId, payloadVersion, contentHash])
  @@index([procurementId])
}

model Artifact {
  id         String       @id @default(uuid())
  sourceRunId String?
  rawEventId String?
  reportId   String?
  kind       ArtifactKind
  bucket     String
  objectKey  String
  mimeType   String?
  checksum   String?
  sizeBytes  Int?
  metadata   Json?
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt
  sourceRun  SourceRun?   @relation(fields: [sourceRunId], references: [id], onDelete: SetNull)
  rawEvent   RawEvent?    @relation(fields: [rawEventId], references: [id], onDelete: SetNull)
  report     Report?      @relation(fields: [reportId], references: [id], onDelete: SetNull)

  @@unique([bucket, objectKey])
  @@index([sourceRunId])
  @@index([rawEventId])
}

model Report {
  id          String       @id @default(uuid())
  name        String
  description String?
  status      ReportStatus @default(PENDING)
  query       Json?
  metadata    Json?
  createdById String?
  deletedAt   DateTime?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  createdBy   User?        @relation(fields: [createdById], references: [id], onDelete: SetNull)
  artifacts   Artifact[]

  @@index([status, createdAt(sort: Desc)])
}

model AuditLog {
  id         String      @id @default(uuid())
  userId     String?
  action     AuditAction
  entityType String
  entityId   String?
  details    Json?
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime    @default(now())
  user       User?       @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([action, createdAt(sort: Desc)])
  @@index([entityType, entityId])
}

model SystemSetting {
  id          String   @id @default(uuid())
  key         String   @unique
  value       Json
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
